{% extends "layouts/base.njk" %}

{% block content %}
{% if body %}
<div class="markdown-body">{{ body | safe }}</div>
{% endif %}

{% if subdirs and subdirs.length > 0 %}
<div class="concept-list">
  {% for sd in subdirs %}
  <a href="{{ sd.path }}" class="concept-card subdir-card">
    <span class="subdir-emoji">{{ sd.emoji }}</span>
    <div class="subdir-info">
      <strong>{{ sd.label }}</strong>
      {% if sd.desc %}
      <p>{{ sd.count }} concept{% if sd.count > 1 %}s{% endif %}</p>
      {% endif %}
    </div>
  </a>
  {% endfor %}
</div>
{% endif %}

{% if concepts and concepts.length > 0 %}
<div class="concept-list">
  {% for c in concepts %}
  <a href="/{{ c.slug }}.html" class="concept-card">
    <span class="type-badge type-{{ c.frontmatter.type | replace(' ', '') }}">{{ c.frontmatter.type }}</span>
    <strong>{{ c.title }}</strong>
    {% if c.frontmatter.description %}
    <p>{{ c.frontmatter.description }}</p>
    {% endif %}
  </a>
  {% endfor %}
</div>
{% endif %}
{% endblock %}
