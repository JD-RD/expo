{% extends "layouts/base.njk" %}

{% block content %}
{% if body %}
<div class="markdown-body">{{ body | safe }}</div>
{% endif %}

{% if concepts and concepts.length > 0 %}
<div class="concept-list">
  {% for c in concepts %}
  <a href="/{{ c.slug }}.html" class="concept-card">
    <span class="type-badge type-{{ c.frontmatter.type | replace(' ', '') }}">{{ c.emoji }} {{ c.frontmatter.type }}</span>
    <strong>{{ c.title }}</strong>
    {% if c.frontmatter.description %}
    <p>{{ c.frontmatter.description }}</p>
    {% endif %}
  </a>
  {% endfor %}
</div>
{% endif %}
{% endblock %}
