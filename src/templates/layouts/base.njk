<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ siteTitle }}</title>
  {% if description %}<meta name="description" content="{{ description }}">{% endif %}
  <link rel="stylesheet" href="/assets/style.css">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>⚡</text></svg>">
  <link rel="apple-touch-icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>⚡</text></svg>">
  <link rel="manifest" href="/manifest.json">
</head>
<body>
  <nav class="topbar">
    {% if tree %}<button class="hamburger" onclick="toggleSidebar()" aria-label="Menu">☰</button>{% endif %}
    <a href="/" class="logo">⚡ EXPO</a>
    <input type="search" id="search" placeholder="Rechercher..." autocomplete="off">
  </nav>

  {% if tree %}<div class="sidebar-overlay" id="sidebar-overlay" onclick="toggleSidebar()"></div>{% endif %}

  <div class="layout">
    {% if tree %}
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-header">
        <span class="sidebar-title">Navigation</span>
        <button class="sidebar-toggle-all" onclick="toggleAllTree()" title="Tout déplier / replier">⊞</button>
        <button class="sidebar-close" onclick="toggleSidebar()" aria-label="Fermer">✕</button>
      </div>
      <div class="tree">
        <div class="tree-root">
          <a href="/{{ bundleName }}/" class="tree-bundle" onclick="closeSidebar(event)">📦 {{ bundleName }}</a>
        </div>
        {% macro render_children(children, startCollapsed=true) %}
          {% if children and children.length > 0 %}
            <ul>
            {% for child in children %}
              <li{% if child.children and child.children.length > 0 and startCollapsed %} class="tree-collapsed"{% endif %}>
                {% if child.children and child.children.length > 0 %}
                <a href="{{ child.path }}" class="tree-dir tree-folder" onclick="return toggleTree(this)">{{ child.label }}</a>
                {% else %}
                <a href="{{ child.path }}" class="tree-dir" onclick="closeSidebar(event)">{{ child.label }}</a>
                {% endif %}
                {{ render_children(child.children, startCollapsed) }}
              </li>
            {% endfor %}
            </ul>
          {% endif %}
        {% endmacro %}
        {{ render_children(tree) }}
      </div>
    </aside>
    {% endif %}

    <main class="content">
      {% if breadcrumb %}
      <nav class="breadcrumb">
        <a href="/">Accueil</a>
        {% for crumb in breadcrumb %}
          <span class="sep">/</span>
          {% if crumb.path %}
            <a href="{{ crumb.path }}">{{ crumb.label }}</a>
          {% else %}
            <span>{{ crumb.label }}</span>
          {% endif %}
        {% endfor %}
      </nav>
      {% endif %}

      {% block content %}{% endblock %}
    </main>
  </div>

  <footer class="site-footer">
    <a href="https://github.com/JD-RD/expo/issues/new" target="_blank" rel="noopener">Signaler une erreur → GitHub Issues</a>
  </footer>

  <script>
    function toggleSidebar() {
      document.body.classList.toggle('sidebar-open');
    }
    function closeSidebar(e) {
      if (window.innerWidth <= 768) {
        document.body.classList.remove('sidebar-open');
      }
    }
    function saveTreeState() {
      const state = {};
      document.querySelectorAll('.tree-folder').forEach(a => {
        state[a.getAttribute('href')] = a.parentElement.classList.contains('tree-collapsed');
      });
      localStorage.setItem('expo-tree', JSON.stringify(state));
    }
    function toggleTree(el) {
      const li = el.parentElement;
      li.classList.toggle('tree-collapsed');
      saveTreeState();
      return false;
    }
    function toggleAllTree() {
      const items = document.querySelectorAll('.tree > ul > li');
      if (items.length === 0) return;
      const allCollapsed = document.querySelectorAll('.tree > ul > li.tree-collapsed').length === items.length;
      for (const li of items) {
        li.classList.toggle('tree-collapsed', !allCollapsed);
      }
      saveTreeState();
    }
    function restoreTreeState() {
      const saved = localStorage.getItem('expo-tree');
      if (!saved) return;
      try {
        const state = JSON.parse(saved);
        document.querySelectorAll('.tree-folder').forEach(a => {
          if (state[a.getAttribute('href')] === false) {
            a.parentElement.classList.remove('tree-collapsed');
          }
        });
      } catch(e) {}
    }
    restoreTreeState();
  </script>
  <script src="/assets/search.js"></script>
</body>
</html>
