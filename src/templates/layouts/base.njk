<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ siteTitle }}</title>
  {% if description %}<meta name="description" content="{{ description }}">{% endif %}
  <link rel="stylesheet" href="/assets/style.css">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>⚡</text></svg>">
  <link rel="apple-touch-icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>⚡</text></svg>">
  <link rel="manifest" href="/manifest.json">
</head>
<body>
  <nav class="topbar">
    {% if tree %}<button class="hamburger" onclick="toggleSidebar()" aria-label="Menu">☰</button>{% endif %}
    <a href="/" class="logo">⚡ EXPO</a>
    <input type="search" id="search" placeholder="Rechercher..." autocomplete="off">
  </nav>

  {% if tree %}<div class="sidebar-overlay" id="sidebar-overlay" onclick="toggleSidebar()"></div>{% endif %}

  <div class="layout">
    {% if tree %}
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-header">
        <span class="sidebar-title">Navigation</span>
        <button class="sidebar-close" onclick="toggleSidebar()" aria-label="Fermer">✕</button>
      </div>
      <div class="tree">
        <div class="tree-root">
          <a href="/{{ bundleName }}/" class="tree-bundle" onclick="closeSidebar(event)">📦 {{ bundleName }}</a>
        </div>
        {% macro render_children(children) %}
          {% if children %}
            <ul>
            {% for child in children %}
              <li>
                <a href="{{ child.path }}" class="tree-dir" onclick="closeSidebar(event)">{{ child.label }}</a>
                {{ render_children(child.children) }}
              </li>
            {% endfor %}
            </ul>
          {% endif %}
        {% endmacro %}
        {{ render_children(tree) }}
      </div>
    </aside>
    {% endif %}

    <main class="content">
      {% if breadcrumb %}
      <nav class="breadcrumb">
        <a href="/">Accueil</a>
        {% for crumb in breadcrumb %}
          <span class="sep">/</span>
          {% if crumb.path %}
            <a href="{{ crumb.path }}">{{ crumb.label }}</a>
          {% else %}
            <span>{{ crumb.label }}</span>
          {% endif %}
        {% endfor %}
      </nav>
      {% endif %}

      {% block content %}{% endblock %}
    </main>
  </div>

  <script>
    function toggleSidebar() {
      document.body.classList.toggle('sidebar-open');
    }
    function closeSidebar(e) {
      if (window.innerWidth <= 768) {
        document.body.classList.remove('sidebar-open');
      }
    }
  </script>
  <script src="/assets/search.js"></script>
</body>
</html>
